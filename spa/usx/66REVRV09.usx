<verse eid="REV 1:6"/><verse number="7" style="v" sid="REV 1:7"/><char style="w" closed="true" strong="G2400">He aquí</char> <char style="w" closed="true" strong="G2064">que viene</char> <char style="w" closed="true" strong="G3326">con</char> <char style="w" closed="true" strong="G3588">las</char> <char style="w" closed="true" strong="G3507">nubes</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3956">todo</char> <char style="w" closed="true" strong="G3788">ojo</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G3700">verá</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3748">los que</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G1574">traspasaron</char>; <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3956">todos</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G5443">linajes</char> <char style="w" closed="true" strong="G3588">de la</char> <char style="w" closed="true" strong="G1093">tierra</char> <char style="w" closed="true" strong="G2875">se lamentarán</char> <char style="w" closed="true" strong="G1909">sobre</char> <char style="w" closed="true" strong="G0846">él</char>. <char style="w" closed="true" strong="G3483">Así sea</char>. <char style="w" closed="true" strong="G0281">Amén</char>. 
