  <para style="p"><verse number="1" style="v" sid="REV 4:1"/><char style="w" closed="true" strong="G3326">DESPUÉS</char> <char style="w" closed="true" strong="G5023">de estas</char> <char style="w" closed="true" strong="G1492">cosas miré</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2400">he aquí</char> <char style="w" closed="true" strong="G2374">una puerta</char> <char style="w" closed="true" strong="G0455">abierta</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G3772">cielo</char>: <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G4413">primera</char> <char style="w" closed="true" strong="G5456">voz</char> <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G0191">oí</char>, <char style="add" closed="true">era</char> <char style="w" closed="true" strong="G5613">como</char> <char style="w" closed="true" strong="G4536">de trompeta</char> <char style="w" closed="true" strong="G2980">que hablaba</char> <char style="w" closed="true" strong="G3326,G1700">conmigo</char>, <char style="w" closed="true" strong="G3004">diciendo</char>: <char style="w" closed="true" strong="G0305">Sube</char> <char style="w" closed="true" strong="G5602">acá</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G4671">yo te</char> <char style="w" closed="true" strong="G1166">mostraré</char> <char style="w" closed="true" strong="G3739">las cosas que</char> <char style="w" closed="true" strong="G3326">han de ser después</char> <char style="w" closed="true" strong="G5023">de éstas</char>. 
