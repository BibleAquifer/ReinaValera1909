  <para style="p"><verse number="1" style="v" sid="REV 1:1"/><char style="w" closed="true" strong="G0602">LA revelación</char> <char style="w" closed="true" strong="G2424,G5547">de Jesucristo</char>, <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G2316">Dios</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G1325">dió</char>, <char style="w" closed="true" strong="G1166">para manifestar</char> <char style="w" closed="true" strong="G0846">á sus</char> <char style="w" closed="true" strong="G1401">siervos</char> <char style="w" closed="true" strong="G3739">las cosas que</char> <char style="w" closed="true" strong="G1163">deben</char> <char style="w" closed="true" strong="G1096">suceder</char> <char style="w" closed="true" strong="G1722,G5034">presto</char>; <char style="w" closed="true" strong="G2532">y</char> <char style="add" closed="true">la</char> <char style="w" closed="true" strong="G4591">declaró</char>, <char style="w" closed="true" strong="G0649">enviándo</char><char style="add" closed="true">la</char> <char style="w" closed="true" strong="G1223">por</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G0032">ángel</char> <char style="w" closed="true" strong="G2491">á Juan</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G1401">siervo</char>, 
<verse eid="REV 1:1"/><verse number="2" style="v" sid="REV 1:2"/><char style="w" closed="true" strong="G3739">El cual</char> <char style="w" closed="true" strong="G3140">ha dado testimonio</char> <char style="w" closed="true" strong="G3588">de la</char> <char style="w" closed="true" strong="G3056">palabra</char> <char style="w" closed="true" strong="G2316">de Dios</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G3141">testimonio</char> <char style="w" closed="true" strong="G2424,G5547">de Jesucristo</char>, <char style="w" closed="true" strong="G3745">y de todas</char> <char style="w" closed="true" strong="G1492">las cosas que ha visto</char>. 
