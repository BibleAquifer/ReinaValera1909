<verse eid="ROM 11:33"/><verse number="34" style="v" sid="ROM 11:34"/><char style="w" closed="true" strong="G1063">Porque</char> ¿<char style="w" closed="true" strong="G5101">quién</char> <char style="w" closed="true" strong="G1097">entendió</char> <char style="w" closed="true" strong="G3563">la mente</char> <char style="w" closed="true" strong="G2962">del Señor</char>? ¿<char style="w" closed="true" strong="G2228">ó</char> <char style="w" closed="true" strong="G5101">quién</char> <char style="w" closed="true" strong="G1096">fué</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G4825">consejero</char>? 
<verse eid="ROM 11:34"/><verse number="35" style="v" sid="ROM 11:35"/>¿<char style="w" closed="true" strong="G2228">O</char> <char style="w" closed="true" strong="G5101">quién</char> <char style="w" closed="true" strong="G1325">le dió</char> <char style="w" closed="true" strong="G0846">á él</char> primero, <char style="w" closed="true" strong="G0846">para que le</char> <char style="w" closed="true" strong="G0467">sea pagado</char>? 
<verse eid="ROM 11:35"/><verse number="36" style="v" sid="ROM 11:36"/><char style="w" closed="true" strong="G3754">Porque</char> <char style="w" closed="true" strong="G1537">de</char> <char style="w" closed="true" strong="G0846">él</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1223">por</char> <char style="w" closed="true" strong="G0846">él</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0846">en él</char>, <char style="w" closed="true" strong="G3956">son todas</char> las cosas. <char style="w" closed="true" strong="G0846">A él</char> <char style="w" closed="true" strong="G1391">sea gloria</char> <char style="w" closed="true" strong="G1519">por</char> <char style="w" closed="true" strong="G0165">siglos</char>. <char style="w" closed="true" strong="G0281">Amén</char>.  
