  <para style="p"><verse number="1" style="v" sid="ROM 14:1"/><char style="w" closed="true" strong="G4355">RECIBID</char> <char style="w" closed="true" strong="G3588">al</char> <char style="w" closed="true" strong="G0770">flaco</char> <char style="w" closed="true" strong="G3588">en</char> <char style="w" closed="true" strong="G4102">la fe</char>, <char style="add" closed="true">pero</char> <char style="w" closed="true" strong="G3361">no</char> <char style="w" closed="true" strong="G1519">para</char> <char style="w" closed="true" strong="G1253">contiendas</char> <char style="w" closed="true" strong="G1261">de disputas</char>. 
<verse eid="ROM 14:1"/><verse number="2" style="v" sid="ROM 14:2"/><char style="w" closed="true" strong="G3303">Porque</char> <char style="w" closed="true" strong="G3739">uno</char> <char style="w" closed="true" strong="G4100">cree</char> <char style="w" closed="true" strong="G5315">que se ha de comer</char> <char style="w" closed="true" strong="G3956">de todas</char> cosas: <char style="w" closed="true" strong="G3588">otro</char> <char style="w" closed="true" strong="G0770">que es débil</char>, <char style="w" closed="true" strong="G2068">come</char> <char style="w" closed="true" strong="G3001">legumbres</char>. 
<verse eid="ROM 14:2"/><verse number="3" style="v" sid="ROM 14:3"/><char style="w" closed="true" strong="G3588">El</char> <char style="w" closed="true" strong="G2068">que come</char>, <char style="w" closed="true" strong="G3361">no</char> <char style="w" closed="true" strong="G1848">menosprecie</char> <char style="w" closed="true" strong="G3588">al</char> <char style="w" closed="true" strong="G3361">que no</char> <char style="w" closed="true" strong="G2068">come</char>: <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G3361">que no</char> <char style="w" closed="true" strong="G2068">come</char>, <char style="w" closed="true" strong="G3361">no</char> <char style="w" closed="true" strong="G2919">juzgue</char> <char style="w" closed="true" strong="G3588">al</char> <char style="w" closed="true" strong="G2068">que come</char>; <char style="w" closed="true" strong="G1063">porque</char> <char style="w" closed="true" strong="G2316">Dios</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G4355">ha levantado</char>. 
<verse eid="ROM 14:3"/><verse number="4" style="v" sid="ROM 14:4"/>¿<char style="w" closed="true" strong="G4771">Tú</char> <char style="w" closed="true" strong="G5101">quién</char> <char style="w" closed="true" strong="G1488">eres</char> <char style="w" closed="true" strong="G3588">que</char> <char style="w" closed="true" strong="G2919">juzgas</char> <char style="w" closed="true" strong="G3610">al siervo</char> <char style="w" closed="true" strong="G0245">ajeno</char>? <char style="w" closed="true" strong="G2962">para su señor</char> <char style="w" closed="true" strong="G4739">está en pie</char>, <char style="w" closed="true" strong="G2228">ó</char> <char style="w" closed="true" strong="G4098">cae</char>: <char style="w" closed="true" strong="G1161">mas</char> <char style="w" closed="true" strong="G2476">se afirmará</char>; <char style="w" closed="true" strong="G1063">que</char> <char style="w" closed="true" strong="G1415">poderoso</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2316">Señor</char> <char style="w" closed="true" strong="G2476,G0846">para afirmarle</char>. 
<verse eid="ROM 14:4"/><verse number="5" style="v" sid="ROM 14:5"/><char style="w" closed="true" strong="G3739">Uno</char> <char style="w" closed="true" strong="G2919">hace diferencia</char> <char style="w" closed="true" strong="G3844">entre</char> <char style="w" closed="true" strong="G2250">día</char> <char style="w" closed="true" strong="G2250">y día</char>; <char style="w" closed="true" strong="G3739">otro</char> <char style="w" closed="true" strong="G2919">juzga</char> <char style="add" closed="true">iguales</char> <char style="w" closed="true" strong="G3956">todos</char> <char style="w" closed="true" strong="G2250">los días</char>. <char style="w" closed="true" strong="G1538">Cada</char> <char style="w" closed="true" strong="G4135">uno esté asegurado</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G2398,G3563">su ánimo</char>. 
