<verse eid="1JN 1:7"/><verse number="8" style="v" sid="1JN 1:8"/><char style="w" closed="true" strong="G1437">Si</char> <char style="w" closed="true" strong="G2036">dijéremos</char> <char style="w" closed="true" strong="G3754">que</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G2192">tenemos</char> <char style="w" closed="true" strong="G0266">pecado</char>, <char style="w" closed="true" strong="G4105">nos engañamos</char> <char style="w" closed="true" strong="G1438">á nosotros</char> mismos, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G0225">hay verdad</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G2254">nosotros</char>. 
