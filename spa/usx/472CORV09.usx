  <para style="p"><verse number="1" style="v" sid="2CO 6:1"/><char style="w" closed="true" strong="G1161">Y</char> <char style="w" closed="true" strong="G1161">ASÍ</char> <char style="add" closed="true">nosotros</char>, <char style="add" closed="true">como</char> <char style="w" closed="true" strong="G4903">ayudadores</char> juntamente <char style="add" closed="true">con él</char>, <char style="add" closed="true">os</char> <char style="w" closed="true" strong="G3870">exhortamos</char> <char style="w" closed="true" strong="G2532">también</char> <char style="w" closed="true" strong="G3361">á que no</char> <char style="w" closed="true" strong="G1209">recibáis</char> <char style="w" closed="true" strong="G1519">en</char> <char style="w" closed="true" strong="G2756">vano</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G5485">gracia</char> <char style="w" closed="true" strong="G2316">de Dios</char>, 
