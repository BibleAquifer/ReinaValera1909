<verse eid="2CO 8:2"/><verse number="3" style="v" sid="2CO 8:3"/><char style="w" closed="true" strong="G3754">Pues</char> <char style="w" closed="true" strong="G0830">de su grado</char> <char style="add" closed="true">han dado</char> <char style="w" closed="true" strong="G2596">conforme</char> <char style="w" closed="true" strong="G1411">á sus fuerzas</char>, <char style="w" closed="true" strong="G3140">yo testifico</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G5228">aun</char> <char style="w" closed="true" strong="G1411">sobre sus fuerzas</char>; 
