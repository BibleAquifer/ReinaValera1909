  <para style="p"><verse number="1" style="v" sid="2CO 7:1"/><char style="w" closed="true" strong="G3767">ASÍ que</char>, <char style="w" closed="true" strong="G0027">amados</char>, <char style="w" closed="true" strong="G2192">pues tenemos</char> <char style="w" closed="true" strong="G3778">tales</char> <char style="w" closed="true" strong="G1860">promesas</char>, <char style="w" closed="true" strong="G2511,G1438">limpiémonos</char> <char style="w" closed="true" strong="G0575">de</char> <char style="w" closed="true" strong="G3956">toda</char> <char style="w" closed="true" strong="G3436">inmundicia</char> <char style="w" closed="true" strong="G0575">de</char> <char style="w" closed="true" strong="G4561">carne</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0575">de</char> <char style="w" closed="true" strong="G4151">espíritu</char>, <char style="w" closed="true" strong="G2005">perfeccionando</char> <char style="w" closed="true" strong="G0042">la santificación</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G5401">temor</char> <char style="w" closed="true" strong="G0575">de</char> <char style="w" closed="true" strong="G2316">Dios</char>. 
<verse eid="2CO 7:1"/><verse number="2" style="v" sid="2CO 7:2"/><char style="w" closed="true" strong="G5562,G2248">Admitidnos</char>: <char style="w" closed="true" strong="G3762">á nadie</char> <char style="w" closed="true" strong="G0091">hemos injuriado</char>, <char style="w" closed="true" strong="G3762">á nadie</char> <char style="w" closed="true" strong="G5351">hemos corrompido</char>, <char style="w" closed="true" strong="G3762">á nadie</char> <char style="w" closed="true" strong="G4122">hemos engañado</char>. 
<verse eid="2CO 7:2"/><verse number="3" style="v" sid="2CO 7:3"/><char style="w" closed="true" strong="G3756">No</char> <char style="w" closed="true" strong="G4314">para</char> <char style="w" closed="true" strong="G2633">condenar</char><char style="add" closed="true">os</char> <char style="w" closed="true" strong="G3004">lo digo</char>; <char style="w" closed="true" strong="G1063">que</char> <char style="w" closed="true" strong="G4280">ya he dicho</char> <char style="w" closed="true" strong="G3754">antes que</char> <char style="w" closed="true" strong="G2075">estáis</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G2257">nuestros</char> <char style="w" closed="true" strong="G2588">corazones</char>, <char style="w" closed="true" strong="G1519">para</char> <char style="w" closed="true" strong="G4880">morir</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1519">para</char> <char style="w" closed="true" strong="G4800">vivir</char> juntamente. 
<verse eid="2CO 7:3"/><verse number="4" style="v" sid="2CO 7:4"/><char style="w" closed="true" strong="G4183">Mucha</char> <char style="w" closed="true" strong="G3954">confianza</char> <char style="w" closed="true" strong="G4314">tengo de</char> <char style="w" closed="true" strong="G5209">vosotros</char>, <char style="w" closed="true" strong="G5228">tengo de</char> <char style="w" closed="true" strong="G5216">vosotros</char> <char style="w" closed="true" strong="G4183">mucha</char> <char style="w" closed="true" strong="G2746">gloria</char>; <char style="w" closed="true" strong="G4137">lleno estoy</char> <char style="w" closed="true" strong="G3874">de consolación</char>, <char style="w" closed="true" strong="G5248">sobreabundo</char> <char style="w" closed="true" strong="G5479">de gozo</char> <char style="w" closed="true" strong="G1909">en</char> <char style="w" closed="true" strong="G3956">todas</char> <char style="w" closed="true" strong="G2257">nuestras</char> <char style="w" closed="true" strong="G2347">tribulaciones</char>. 
<verse eid="2CO 7:4"/><verse number="5" style="v" sid="2CO 7:5"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G2064,G2257">aun cuando vinimos</char> <char style="w" closed="true" strong="G1519">á</char> <char style="w" closed="true" strong="G3109">Macedonia</char>, <char style="w" closed="true" strong="G3762">ningún</char> <char style="w" closed="true" strong="G0425">reposo</char> <char style="w" closed="true" strong="G2192">tuvo</char> <char style="w" closed="true" strong="G2257">nuestra</char> <char style="w" closed="true" strong="G4561">carne</char>; <char style="w" closed="true" strong="G0235">antes</char>, <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3956">todo</char> <char style="w" closed="true" strong="G2346">fuimos atribulados</char>: <char style="w" closed="true" strong="G1855">de fuera</char>, <char style="w" closed="true" strong="G3163">cuestiones</char>; <char style="w" closed="true" strong="G2081">de dentro</char>, <char style="w" closed="true" strong="G5401">temores</char>. 
