<verse eid="2CO 3:17"/><verse number="18" style="v" sid="2CO 3:18"/><char style="w" closed="true" strong="G1161">Por tanto</char>, <char style="w" closed="true" strong="G2249">nosotros</char> <char style="w" closed="true" strong="G3956">todos</char>, <char style="w" closed="true" strong="G4383">mirando á cara</char> <char style="w" closed="true" strong="G0343">descubierta</char> <char style="w" closed="true" strong="G2734">como en un espejo</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G1391">gloria</char> <char style="w" closed="true" strong="G2962">del Señor</char>, <char style="w" closed="true" strong="G3339">somos transformados</char> <char style="w" closed="true" strong="G0575">de</char> <char style="w" closed="true" strong="G1391">gloria</char> <char style="w" closed="true" strong="G1519">en</char> <char style="w" closed="true" strong="G1391">gloria</char> <char style="w" closed="true" strong="G1519">en</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G0846">misma</char> semejanza, <char style="w" closed="true" strong="G2509">como</char> <char style="w" closed="true" strong="G4151">por el Espíritu</char> <char style="w" closed="true" strong="G0575">del</char> <char style="w" closed="true" strong="G2962">Señor</char>.  
<verse eid="2CO 3:18"/><verse eid="2CO 3:18"/></para>
