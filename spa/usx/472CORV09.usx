<verse eid="2CO 7:11"/><verse number="12" style="v" sid="2CO 7:12"/><char style="w" closed="true" strong="G0686">Así</char> que, <char style="w" closed="true" strong="G1487,G2532">aunque</char> <char style="w" closed="true" strong="G5213">os</char> <char style="w" closed="true" strong="G1125">escribí</char>, <char style="w" closed="true" strong="G3756">no</char> <char style="add" closed="true">fué</char> <char style="w" closed="true" strong="G1752">por causa</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G0091">que hizo la injuria</char>, <char style="w" closed="true" strong="G3761">ni</char> <char style="w" closed="true" strong="G1752">por causa</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G0091">que la padeció</char>, <char style="w" closed="true" strong="G0235">mas</char> <char style="w" closed="true" strong="G1752">para que</char> <char style="w" closed="true" strong="G5213">os</char> <char style="w" closed="true" strong="G5319">fuese manifiesta</char> <char style="w" closed="true" strong="G5216">nuestra</char> <char style="w" closed="true" strong="G4710">solicitud</char> <char style="w" closed="true" strong="G2257,G5228">que</char> <char style="w" closed="true" strong="G4314">tenemos</char> <char style="w" closed="true" strong="G5209">por</char> <char style="w" closed="true" strong="G1799">vosotros</char> <char style="w" closed="true" strong="G2316">delante de Dios</char>. 
