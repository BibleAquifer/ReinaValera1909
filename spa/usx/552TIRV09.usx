<verse eid="2TI 3:10"/><verse number="11" style="v" sid="2TI 3:11"/><char style="w" closed="true" strong="G1375">Persecuciones</char>, <char style="w" closed="true" strong="G3804">aflicciones</char>, <char style="w" closed="true" strong="G3427">cuales me</char> <char style="w" closed="true" strong="G1096">sobrevinieron</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G0490">Antioquía</char>, <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G2430">Iconio</char>, <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3082">Listra</char>, <char style="w" closed="true" strong="G1375">cuales persecuciones</char> <char style="w" closed="true" strong="G5297">he sufrido</char>; <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1537">de</char> <char style="w" closed="true" strong="G3956">todas</char> <char style="w" closed="true" strong="G3165">me</char> <char style="w" closed="true" strong="G4506">ha librado</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2962">Señor</char>. 
<verse eid="2TI 3:11"/><verse number="12" style="v" sid="2TI 3:12"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G1161">también</char> <char style="w" closed="true" strong="G3956">todos</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G2309">que quieren</char> <char style="w" closed="true" strong="G2198">vivir</char> <char style="w" closed="true" strong="G2153">píamente</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G5547">Cristo</char> <char style="w" closed="true" strong="G2424">Jesús</char>, <char style="w" closed="true" strong="G1377">padecerán persecución</char>. 
<verse eid="2TI 3:12"/><verse number="13" style="v" sid="2TI 3:13"/><char style="w" closed="true" strong="G1161">Mas</char> <char style="w" closed="true" strong="G4190">los malos</char> <char style="w" closed="true" strong="G0444">hombres</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1114">los engañadores</char>, <char style="w" closed="true" strong="G4298">irán</char> <char style="w" closed="true" strong="G1909,G5501">de mal en peor</char>, <char style="w" closed="true" strong="G4105">engañando</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G4105">siendo engañados</char>. 
<verse eid="2TI 3:13"/><verse number="14" style="v" sid="2TI 3:14"/><char style="w" closed="true" strong="G1161">Empero</char> <char style="w" closed="true" strong="G3306">persiste</char> <char style="w" closed="true" strong="G4771">tú</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3739">lo que</char> <char style="w" closed="true" strong="G3129">has aprendido</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G4104">te persuadiste</char>, <char style="w" closed="true" strong="G1492">sabiendo</char> <char style="w" closed="true" strong="G3844">de</char> <char style="w" closed="true" strong="G5101">quién</char> <char style="w" closed="true" strong="G3129">has aprendido</char>; 
