  <para style="p"><verse number="1" style="v" sid="2TI 4:1"/><char style="w" closed="true" strong="G1263">REQUIERO</char> <char style="w" closed="true" strong="G1799">yo pues delante</char> <char style="w" closed="true" strong="G2316">de Dios</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G2962">Señor</char> <char style="w" closed="true" strong="G2424,G5547">Jesucristo</char>, <char style="w" closed="true" strong="G3195">que ha</char> <char style="w" closed="true" strong="G2919">de juzgar</char> <char style="w" closed="true" strong="G2198">á los vivos</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3498">los muertos</char> <char style="w" closed="true" strong="G2596">en</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G2015">manifestación</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2596">en</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G0932">reino</char>, 
<verse eid="2TI 4:1"/><verse number="2" style="v" sid="2TI 4:2"/><char style="w" closed="true" strong="G2784">Que prediques</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G3056">palabra</char>; <char style="w" closed="true" strong="G2186">que instes</char> <char style="w" closed="true" strong="G2122">á tiempo</char> <char style="w" closed="true" strong="G0171">y fuera de tiempo</char>; <char style="w" closed="true" strong="G1651">redarguye</char>, <char style="w" closed="true" strong="G2008">reprende</char>, <char style="w" closed="true" strong="G3870">exhorta</char> <char style="w" closed="true" strong="G1722">con</char> <char style="w" closed="true" strong="G3956">toda</char> <char style="w" closed="true" strong="G3115">paciencia</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1322">doctrina</char>. 
<verse eid="2TI 4:2"/><verse number="3" style="v" sid="2TI 4:3"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G2071">vendrá</char> <char style="w" closed="true" strong="G2540">tiempo</char> <char style="w" closed="true" strong="G3753">cuando</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G0430">sufrirán</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G5198">sana</char> <char style="w" closed="true" strong="G1319">doctrina</char>; <char style="w" closed="true" strong="G0235">antes</char>, <char style="w" closed="true" strong="G2833">teniendo comezón</char> <char style="w" closed="true" strong="G0189">de oir</char>, <char style="w" closed="true" strong="G2002">se amontonarán</char> <char style="w" closed="true" strong="G1320">maestros</char> <char style="w" closed="true" strong="G2596">conforme</char> <char style="w" closed="true" strong="G1438">á sus</char> <char style="w" closed="true" strong="G1939">concupiscencias</char>, 
<verse eid="2TI 4:3"/><verse number="4" style="v" sid="2TI 4:4"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G0654">apartarán</char> <char style="w" closed="true" strong="G0575">de</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G0225">verdad</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0189">oído</char>, <char style="w" closed="true" strong="G1161">y</char> <char style="w" closed="true" strong="G1624">se volverán</char> <char style="w" closed="true" strong="G1909">á</char> <char style="w" closed="true" strong="G3588">las</char> <char style="w" closed="true" strong="G3454">fábulas</char>. 
<verse eid="2TI 4:4"/><verse number="5" style="v" sid="2TI 4:5"/><char style="w" closed="true" strong="G1161">Pero</char> <char style="w" closed="true" strong="G4771">tú</char> <char style="w" closed="true" strong="G3525">vela</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3956">todo</char>, <char style="w" closed="true" strong="G2553">soporta</char> las aflicciones, <char style="w" closed="true" strong="G4160">haz</char> <char style="w" closed="true" strong="G2041">la obra</char> <char style="w" closed="true" strong="G2099">de evangelista</char>, <char style="w" closed="true" strong="G4135">cumple</char> <char style="w" closed="true" strong="G4675">tu</char> <char style="w" closed="true" strong="G1248">ministerio</char>. 
<verse eid="2TI 4:5"/><verse number="6" style="v" sid="2TI 4:6"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G1473">yo</char> <char style="w" closed="true" strong="G2235">ya</char> <char style="w" closed="true" strong="G4689">estoy para ser ofrecido</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2540">tiempo</char> <char style="w" closed="true" strong="G1699">de mi</char> <char style="w" closed="true" strong="G0359">partida</char> <char style="w" closed="true" strong="G2186">está cercano</char>. 
<verse eid="2TI 4:6"/><verse number="7" style="v" sid="2TI 4:7"/><char style="w" closed="true" strong="G0075">He peleado</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G2570">buena</char> <char style="w" closed="true" strong="G0073">batalla</char>, <char style="w" closed="true" strong="G5055">he acabado</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G1408">carrera</char>, <char style="w" closed="true" strong="G5083">he guardado</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G4102">fe</char>. 
