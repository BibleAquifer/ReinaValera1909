<verse eid="2TI 3:15"/><verse number="16" style="v" sid="2TI 3:16"/><char style="w" closed="true" strong="G3956">Toda</char> <char style="w" closed="true" strong="G1124">Escritura</char> <char style="add" closed="true">es</char> <char style="w" closed="true" strong="G2315">inspirada</char> <char style="w" closed="true" strong="G2532">divinamente y</char> <char style="w" closed="true" strong="G5624">útil</char> <char style="w" closed="true" strong="G4314">para</char> <char style="w" closed="true" strong="G1319">enseñar</char>, <char style="w" closed="true" strong="G4314">para</char> <char style="w" closed="true" strong="G1650">redargüir</char>, <char style="w" closed="true" strong="G4314">para</char> <char style="w" closed="true" strong="G1882">corregir</char>, <char style="w" closed="true" strong="G4314">para</char> <char style="w" closed="true" strong="G3809">instituir</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G1343">justicia</char>, 
<verse eid="2TI 3:16"/><verse number="17" style="v" sid="2TI 3:17"/><char style="w" closed="true" strong="G4314">Para</char> <char style="w" closed="true" strong="G3588">que el</char> <char style="w" closed="true" strong="G0444">hombre</char> <char style="w" closed="true" strong="G2316">de Dios</char> <char style="w" closed="true" strong="G5600">sea</char> <char style="w" closed="true" strong="G0739">perfecto</char>, <char style="w" closed="true" strong="G1822">enteramente instruído</char> <char style="w" closed="true" strong="G4314">para</char> <char style="w" closed="true" strong="G3956">toda</char> <char style="w" closed="true" strong="G0018">buena</char> <char style="w" closed="true" strong="G2041">obra</char>.  
