  <chapter eid="2TI 2"/>
  <chapter number="3" style="c" sid="2TI 3"/>
  <para style="p"><verse number="1" style="v" sid="2TI 3:1"/><char style="w" closed="true" strong="G5124">ESTO</char> <char style="w" closed="true" strong="G1161">también</char> sepas, <char style="w" closed="true" strong="G3754">que</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G2078">los postreros</char> <char style="w" closed="true" strong="G2250">días</char> <char style="w" closed="true" strong="G1764">vendrán</char> <char style="w" closed="true" strong="G2540">tiempos</char> <char style="w" closed="true" strong="G5467">peligrosos</char>: 
<verse eid="2TI 3:1"/><verse number="2" style="v" sid="2TI 3:2"/><char style="w" closed="true" strong="G2071">Que habrá</char> <char style="w" closed="true" strong="G0444">hombres</char> <char style="w" closed="true" strong="G5367">amadores de sí mismos</char>, <char style="w" closed="true" strong="G5366">avaros</char>, <char style="w" closed="true" strong="G0213">vanagloriosos</char>, <char style="w" closed="true" strong="G5244">soberbios</char>, <char style="w" closed="true" strong="G0989">detractores</char>, <char style="w" closed="true" strong="G0545">desobedientes</char> <char style="w" closed="true" strong="G1118">á los padres</char>, <char style="w" closed="true" strong="G0884">ingratos</char>, <char style="w" closed="true" strong="G0462">sin santidad</char>, 
