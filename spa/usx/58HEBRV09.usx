<verse eid="HEB 8:7"/><verse number="8" style="v" sid="HEB 8:8"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G3201,G0846">reprendiéndolos</char> <char style="w" closed="true" strong="G3004">dice</char>: <char style="w" closed="true" strong="G2400">He aquí</char> <char style="w" closed="true" strong="G2064">vienen</char> <char style="w" closed="true" strong="G2250">días</char>, <char style="w" closed="true" strong="G3004">dice</char> <char style="w" closed="true" strong="G2962">el Señor</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G4931">consumaré</char> <char style="w" closed="true" strong="G1909">para con</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G3624">casa</char> <char style="w" closed="true" strong="G2474">de Israel</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1909">para con</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G3624">casa</char> <char style="w" closed="true" strong="G2448">de Judá</char> <char style="w" closed="true" strong="G2537">un nuevo</char> <char style="w" closed="true" strong="G1242">pacto</char>; 
<verse eid="HEB 8:8"/><verse number="9" style="v" sid="HEB 8:9"/><char style="w" closed="true" strong="G3756">No</char> <char style="w" closed="true" strong="G2596">como</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G1242">pacto</char> <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G4160">hice</char> <char style="w" closed="true" strong="G0846">con sus</char> <char style="w" closed="true" strong="G3962">padres</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G1722,G2250">día</char> <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G1949">los tomé</char> <char style="w" closed="true" strong="G3588">por la</char> <char style="w" closed="true" strong="G5495">mano</char> <char style="w" closed="true" strong="G1806,G0846">para sacarlos</char> <char style="w" closed="true" strong="G3588">de la</char> <char style="w" closed="true" strong="G1093">tierra</char> <char style="w" closed="true" strong="G0125">de Egipto</char>: <char style="w" closed="true" strong="G3754">porque</char> <char style="w" closed="true" strong="G0846">ellos</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G1696">permanecieron</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3450">mi</char> <char style="w" closed="true" strong="G1242">pacto</char>, <char style="w" closed="true" strong="G2504">y yo</char> <char style="w" closed="true" strong="G0846">los</char> <char style="w" closed="true" strong="G0272">menosprecié</char>, <char style="w" closed="true" strong="G3004">dice</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2962">Señor</char>. 
<verse eid="HEB 8:9"/><verse number="10" style="v" sid="HEB 8:10"/><char style="w" closed="true" strong="G3754">Por</char> lo cual, <char style="w" closed="true" strong="G3778">este</char> <char style="w" closed="true" strong="G3588">es el</char> <char style="w" closed="true" strong="G1242">pacto</char> <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G1303">ordenaré</char> <char style="w" closed="true" strong="G3588">á la</char> <char style="w" closed="true" strong="G3624">casa</char> <char style="w" closed="true" strong="G2474">de Israel</char> <char style="w" closed="true" strong="G3326">después</char> <char style="w" closed="true" strong="G1565">de aquellos</char> <char style="w" closed="true" strong="G2250">días</char>, <char style="w" closed="true" strong="G3004">dice</char> <char style="w" closed="true" strong="G2962">el Señor</char>: <char style="w" closed="true" strong="G1325">Daré</char> <char style="w" closed="true" strong="G3450">mis</char> <char style="w" closed="true" strong="G3551">leyes</char> <char style="w" closed="true" strong="G1519">en</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G1271">alma</char> <char style="w" closed="true" strong="G0846">de ellos</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1909">sobre</char> <char style="w" closed="true" strong="G2588">el corazón</char> <char style="w" closed="true" strong="G0846">de ellos</char> <char style="w" closed="true" strong="G0846">las</char> <char style="w" closed="true" strong="G1924">escribiré</char>; <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2071">seré</char> <char style="w" closed="true" strong="G0846">á ellos</char> <char style="w" closed="true" strong="G1519">por</char> <char style="w" closed="true" strong="G2316">Dios</char>, <char style="w" closed="true" strong="G2532">y</char> <char s