<verse eid="HEB 13:8"/><verse number="9" style="v" sid="HEB 13:9"/><char style="w" closed="true" strong="G3361">No</char> <char style="w" closed="true" strong="G4064">seáis llevados de acá para allá</char> <char style="w" closed="true" strong="G1322">por doctrinas</char> <char style="w" closed="true" strong="G4164">diversas</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3581">extrañas</char>; <char style="w" closed="true" strong="G1063">porque</char> <char style="w" closed="true" strong="G2570">buena</char> <char style="w" closed="true" strong="G0950">cosa es afirmar</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2588">corazón</char> <char style="w" closed="true" strong="G5485">en la gracia</char>, <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G1033">en viandas</char>, <char style="w" closed="true" strong="G3756">que nunca</char> <char style="w" closed="true" strong="G5623">aprovecharon</char> <char style="w" closed="true" strong="G4043">á los que anduvieron</char> <char style="w" closed="true" strong="G3739">en ellas</char>. 
