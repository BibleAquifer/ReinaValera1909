<verse eid="HEB 8:2"/><verse number="3" style="v" sid="HEB 8:3"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G3956">todo</char> <char style="w" closed="true" strong="G0749">pontífice</char> <char style="w" closed="true" strong="G2525">es puesto</char> <char style="w" closed="true" strong="G1519">para</char> <char style="w" closed="true" strong="G1435">ofrecer</char> <char style="w" closed="true" strong="G4374">presentes</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2378">sacrificios</char>; <char style="w" closed="true" strong="G3606">por</char> <char style="w" closed="true" strong="G0316">lo cual es necesario</char> <char style="w" closed="true" strong="G2532">que también</char> <char style="w" closed="true" strong="G5126">éste</char> <char style="w" closed="true" strong="G2192">tuviese</char> <char style="w" closed="true" strong="G5100">algo</char> <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G4374">ofrecer</char>. 
<verse eid="HEB 8:3"/><verse number="4" style="v" sid="HEB 8:4"/><char style="w" closed="true" strong="G1063">Así</char> que, <char style="w" closed="true" strong="G1487">si</char> <char style="w" closed="true" strong="G2258">estuviese</char> <char style="w" closed="true" strong="G1909">sobre</char> <char style="w" closed="true" strong="G1093">la tierra</char>, <char style="w" closed="true" strong="G3761,G0302">ni</char> <char style="w" closed="true" strong="G2258">aun sería</char> <char style="w" closed="true" strong="G2409">sacerdote</char>, <char style="w" closed="true" strong="G5607">habiendo</char> <char style="w" closed="true" strong="G2409">aún</char> <char style="w" closed="true" strong="G4374">los sacerdotes que ofrecen</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G1435">presentes</char> <char style="w" closed="true" strong="G2596">según</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G3551">ley</char>; 
