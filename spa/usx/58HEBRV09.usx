<verse eid="HEB 8:5"/><verse number="6" style="v" sid="HEB 8:6"/><char style="w" closed="true" strong="G1161">Mas</char> <char style="w" closed="true" strong="G3570">ahora</char> <char style="w" closed="true" strong="G1313">tanto mejor</char> <char style="w" closed="true" strong="G3009">ministerio</char> <char style="w" closed="true" strong="G5177">es</char> el suyo, <char style="w" closed="true" strong="G3745">cuanto</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G3316">mediador</char> <char style="w" closed="true" strong="G2909">de un mejor</char> <char style="w" closed="true" strong="G1242">pacto</char>, <char style="w" closed="true" strong="G3549">el cual ha sido formado</char> <char style="w" closed="true" strong="G1909">sobre</char> <char style="w" closed="true" strong="G2909">mejores</char> <char style="w" closed="true" strong="G1860">promesas</char>. 
