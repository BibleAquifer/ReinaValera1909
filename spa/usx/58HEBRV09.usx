  <para style="p"><verse number="1" style="v" sid="HEB 8:1"/><char style="w" closed="true" strong="G1161">ASÍ que</char>, <char style="w" closed="true" strong="G2774">la suma</char> <char style="w" closed="true" strong="G1909">acerca de</char> <char style="w" closed="true" strong="G3588">lo</char> dicho <char style="add" closed="true">es</char>: <char style="w" closed="true" strong="G2192">Tenemos</char> <char style="w" closed="true" strong="G5108">tal</char> <char style="w" closed="true" strong="G0749">pontífice</char> <char style="w" closed="true" strong="G2523">que se asentó</char> <char style="w" closed="true" strong="G1722">á</char> <char style="w" closed="true" strong="G1188">la diestra</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G2362">trono</char> <char style="w" closed="true" strong="G1909">de</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G3172">Majestad</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G3772">cielos</char>; 
