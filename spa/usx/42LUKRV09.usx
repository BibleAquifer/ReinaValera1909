<verse eid="LUK 23:52"/><verse number="53" style="v" sid="LUK 23:53"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G2507">quitado</char>, <char style="w" closed="true" strong="G0846">lo</char> <char style="w" closed="true" strong="G1794">envolvió</char> <char style="w" closed="true" strong="G4616">en una sábana</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G5087">le puso</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3418">un sepulcro</char> <char style="w" closed="true" strong="G1722">abierto en</char> <char style="w" closed="true" strong="G2991">una peña</char>, <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3757">el cual</char> <char style="w" closed="true" strong="G3762">ninguno</char> <char style="w" closed="true" strong="G2258">había</char> <char style="w" closed="true" strong="G3764">aún</char> <char style="w" closed="true" strong="G2749">sido puesto</char>. 
<verse eid="LUK 23:53"/><verse number="54" style="v" sid="LUK 23:54"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G2258">era</char> <char style="w" closed="true" strong="G2250">día</char> <char style="w" closed="true" strong="G3904">de la víspera</char> <char style="add" closed="true">de la Pascua</char>; <char style="w" closed="true" strong="G2532">y estaba</char> <char style="w" closed="true" strong="G2020">para rayar</char> <char style="w" closed="true" strong="G4521">el sábado</char>. 
<verse eid="LUK 23:54"/><verse number="55" style="v" sid="LUK 23:55"/><char style="w" closed="true" strong="G1161">Y</char> <char style="w" closed="true" strong="G1135">las mujeres</char> <char style="w" closed="true" strong="G3748">que</char> <char style="w" closed="true" strong="G0846">con él</char> <char style="w" closed="true" strong="G2258">habían</char> <char style="w" closed="true" strong="G4905">venido</char> <char style="w" closed="true" strong="G1056">de Galilea</char>, <char style="w" closed="true" strong="G2628">siguieron</char> <char style="w" closed="true" strong="G2532">también y</char> <char style="w" closed="true" strong="G2300">vieron</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G3419">sepulcro</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G5613">cómo</char> <char style="w" closed="true" strong="G5087">fué puesto</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G4983">cuerpo</char>. 
<verse eid="LUK 23:55"/><verse number="56" style="v" sid="LUK 23:56"/><char style="w" closed="true" strong="G1161">Y</char> <char style="w" closed="true" strong="G5290">vueltas</char>, <char style="w" closed="true" strong="G2090">aparejaron</char> <char style="add" closed="true">drogas</char> <char style="w" closed="true" strong="G0759">aromáticas</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3464">ungüentos</char>; <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2270">reposaron</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G4521">sábado</char>, <char style="w" closed="true" strong="G2596">conforme</char> <char style="w" closed="true" strong="G3588">al</char> <char style="w" closed="true" strong="G1785">mandamiento</char>.  
