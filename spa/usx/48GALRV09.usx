<verse eid="GAL 2:8"/><verse number="9" style="v" sid="GAL 2:9"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G1097">como vieron</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G5485">gracia</char> <char style="w" closed="true" strong="G3588">que</char> <char style="w" closed="true" strong="G3427">me</char> <char style="w" closed="true" strong="G1325">era dada</char>, <char style="w" closed="true" strong="G2385">Jacobo</char> <char style="w" closed="true" strong="G2786">y Cefas</char> <char style="w" closed="true" strong="G2491">y Juan</char>, <char style="w" closed="true" strong="G3588">que</char> <char style="w" closed="true" strong="G1380">parecían</char> <char style="w" closed="true" strong="G1511">ser</char> <char style="w" closed="true" strong="G4769">las columnas</char>, <char style="w" closed="true" strong="G1325">nos dieron</char> <char style="w" closed="true" strong="G1188">las diestras</char> <char style="w" closed="true" strong="G2842">de compañía</char> <char style="w" closed="true" strong="G1698">á mí</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0921">á Bernabé</char>, <char style="w" closed="true" strong="G2443">para que</char> <char style="w" closed="true" strong="G2249">nosotros</char> <char style="w" closed="true" strong="G1519">fuésemos á</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G1483">Gentiles</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0846">ellos</char> <char style="w" closed="true" strong="G1519">á</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G4061">circuncisión</char>. 
<verse eid="GAL 2:9"/><verse number="10" style="v" sid="GAL 2:10"/><char style="w" closed="true" strong="G3440">Solamente</char> <char style="add" closed="true">nos pidieron</char> <char style="w" closed="true" strong="G2443">que</char> <char style="w" closed="true" strong="G3421">nos acordásemos</char> <char style="w" closed="true" strong="G3588">de los</char> <char style="w" closed="true" strong="G4434">pobres</char>; <char style="w" closed="true" strong="G3739">lo</char> <char style="w" closed="true" strong="G2443">mismo que</char> <char style="w" closed="true" strong="G2532">fuí también</char> <char style="w" closed="true" strong="G4704">solícito</char> <char style="w" closed="true" strong="G4160">en hacer</char>. 
<verse eid="GAL 2:10"/><verse number="11" style="v" sid="GAL 2:11"/><char style="w" closed="true" strong="G1161">Empero</char> <char style="w" closed="true" strong="G2064">viniendo</char> <char style="w" closed="true" strong="G1565">Pedro</char> <char style="w" closed="true" strong="G1519">á</char> <char style="w" closed="true" strong="G0490">Antioquía</char>, <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G0436">resistí</char> <char style="w" closed="true" strong="G2596">en</char> <char style="w" closed="true" strong="G4383">la cara</char>, <char style="w" closed="true" strong="G3754">porque</char> <char style="w" closed="true" strong="G2258">era</char> <char style="w" closed="true" strong="G2607">de condenar</char>. 
