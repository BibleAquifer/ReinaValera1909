<verse eid="GAL 2:12"/><verse number="13" style="v" sid="GAL 2:13"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G0846">á su</char> <char style="w" closed="true" strong="G4942">disimulación</char> <char style="w" closed="true" strong="G2532">consentían también</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G3062">otros</char> <char style="w" closed="true" strong="G2453">Judíos</char>; <char style="w" closed="true" strong="G5620">de tal</char> <char style="w" closed="true" strong="G2532">manera que aun</char> <char style="w" closed="true" strong="G0921">Bernabé</char> <char style="w" closed="true" strong="G2532">fué también</char> <char style="w" closed="true" strong="G4879">llevado</char> <char style="add" closed="true">de ellos</char> <char style="w" closed="true" strong="G0846">en su</char> <char style="w" closed="true" strong="G4942">simulación</char>. 
<verse eid="GAL 2:13"/><verse number="14" style="v" sid="GAL 2:14"/><char style="w" closed="true" strong="G0235">Mas</char> <char style="w" closed="true" strong="G3753">cuando</char> <char style="w" closed="true" strong="G1492">vi</char> <char style="w" closed="true" strong="G3754">que</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G3716">andaban derechamente</char> <char style="w" closed="true" strong="G4314">conforme</char> <char style="w" closed="true" strong="G3588">á la</char> <char style="w" closed="true" strong="G0225">verdad</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G2098">evangelio</char>, <char style="w" closed="true" strong="G2036">dije</char> <char style="w" closed="true" strong="G1565">á Pedro</char> <char style="w" closed="true" strong="G1715">delante</char> <char style="w" closed="true" strong="G3956">de todos</char>: <char style="w" closed="true" strong="G1487">Si</char> <char style="w" closed="true" strong="G4771">tú</char>, <char style="w" closed="true" strong="G5225">siendo</char> <char style="w" closed="true" strong="G2453">Judío</char>, <char style="w" closed="true" strong="G2198">vives</char> <char style="w" closed="true" strong="G1483">como los Gentiles</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G2453">como Judío</char>, ¿<char style="w" closed="true" strong="G5101">por qué</char> <char style="w" closed="true" strong="G0315">constriñes</char> <char style="w" closed="true" strong="G3588">á los</char> <char style="w" closed="true" strong="G1483">Gentiles</char> <char style="w" closed="true" strong="G2450">á judaizar</char>? 
