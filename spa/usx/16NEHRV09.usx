<verse eid="NEH 12:13"/><verse number="14" style="v" sid="NEH 12:14"/><char style="w" closed="true" strong="H4409">De Melichâ</char>, <char style="w" closed="true" strong="H3129">Jonathán</char>; <char style="w" closed="true" strong="H7645">de Sebanías</char>, <char style="w" closed="true" strong="H3130">Joseph</char>; 
