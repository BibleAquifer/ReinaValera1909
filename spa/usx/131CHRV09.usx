<verse eid="1CH 2:51"/><verse number="52" style="v" sid="1CH 2:52"/><char style="w" closed="true" strong="H1121">Y los hijos</char> <char style="w" closed="true" strong="H7732">de Sobal</char> <char style="w" closed="true" strong="H0001">padre</char> <char style="w" closed="true" strong="H7157">de Chîriath-jearim</char> <char style="w" closed="true" strong="H1961">fueron</char> <char style="w" closed="true" strong="H7204">Haroeh</char>, <char style="w" closed="true" strong="H2677">la mitad</char> <char style="w" closed="true" strong="H4496">de los Manahethitas</char>. 
<verse eid="1CH 2:52"/><verse number="53" style="v" sid="1CH 2:53"/><char style="w" closed="true" strong="H4940">Y las familias</char> <char style="w" closed="true" strong="H7157">de Chîriath-jearim</char> <char style="w" closed="true" strong="H3505">fueron los Ithreos</char>, <char style="w" closed="true" strong="H6336">y los Phuteos</char>, <char style="w" closed="true" strong="H8126">y los Samatheos</char>, <char style="w" closed="true" strong="H4954">y los Misraiteos</char>; <char style="w" closed="true" strong="H0428">de los cuales</char> <char style="w" closed="true" strong="H3318">salieron</char> <char style="w" closed="true" strong="H6882">los Soratitas</char>, <char style="w" closed="true" strong="H0848">y los Estaolitas</char>. 
<verse eid="1CH 2:53"/><verse number="54" style="v" sid="1CH 2:54"/><char style="w" closed="true" strong="H1121">Los hijos</char> <char style="w" closed="true" strong="H8007">de Salma</char>: <char style="w" closed="true" strong="H1035">Beth-lehem</char>, <char style="w" closed="true" strong="H5200">y los Nethophatitas</char>, <char style="add" closed="true">los cuales son</char> <char style="w" closed="true" strong="H5852,H1004,H3097,H5854">las coronas de la casa de Joab</char>, <char style="w" closed="true" strong="H2677">y de la mitad</char> <char style="w" closed="true" strong="H5200">de los Manahethitas</char>, <char style="w" closed="true" strong="H6882">los Soraitas</char>. 
<verse eid="1CH 2:54"/><verse number="55" style="v" sid="1CH 2:55"/><char style="w" closed="true" strong="H4940">Y las familias</char> <char style="w" closed="true" strong="H5608">de los escribas</char>, <char style="w" closed="true" strong="H3427">que moraban</char> <char style="w" closed="true" strong="H3258">en Jabes</char>, <char style="w" closed="true" strong="H8654">fueron los Thiratheos</char>, <char style="w" closed="true" strong="H8101">Simatheos</char>, <char style="w" closed="true" strong="H7756">Sucatheos</char>; <char style="w" closed="true" strong="H1992">los cuales</char> <char style="w" closed="true" strong="H7017">son los Cineos</char> <char style="w" closed="true" strong="H0935">que vinieron</char> <char style="w" closed="true" strong="H2575">de Hamath</char>, <char style="w" closed="true" strong="H0001">padre</char> <char style="w" closed="true" strong="H1004">de la casa</char> <char style="w" closed="true" strong="H7394">de Rechâb</char>.  
