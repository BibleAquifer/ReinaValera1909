<verse eid="1CH 2:48"/><verse number="49" style="v" sid="1CH 2:49"/><char style="w" closed="true" strong="H3205">Y también le parió</char> <char style="w" closed="true" strong="H8174">á Saaph</char> <char style="w" closed="true" strong="H0001">padre</char> <char style="w" closed="true" strong="H4089">de Madmannah</char>, <char style="w" closed="true" strong="H7724">y á Seva</char> <char style="w" closed="true" strong="H0001">padre</char> <char style="w" closed="true" strong="H4343">de Macbena</char>, <char style="w" closed="true" strong="H0001">y padre</char> <char style="w" closed="true" strong="H1388">de Ghiba</char>. <char style="w" closed="true" strong="H5915">Y Achsa</char> <char style="w" closed="true" strong="H1323">fué hija</char> <char style="w" closed="true" strong="H3612">de Caleb</char>. 
