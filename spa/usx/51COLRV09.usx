<verse eid="COL 2:4"/><verse number="5" style="v" sid="COL 2:5"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G1487">aunque</char> <char style="w" closed="true" strong="G0548">estoy ausente</char> <char style="w" closed="true" strong="G4862">con</char> <char style="w" closed="true" strong="G4561">el cuerpo</char>, <char style="w" closed="true" strong="G0235">no obstante</char> <char style="w" closed="true" strong="G4862">con</char> <char style="w" closed="true" strong="G4151">el espíritu</char> <char style="w" closed="true" strong="G1510">estoy</char> <char style="w" closed="true" strong="G4862">con</char> <char style="w" closed="true" strong="G5213">vosotros</char>, <char style="w" closed="true" strong="G5463">gozándome</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0991">mirando</char> <char style="w" closed="true" strong="G5216">vuestro</char> <char style="w" closed="true" strong="G5010">concierto</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G4733">firmeza</char> <char style="w" closed="true" strong="G5216">de vuestra</char> <char style="w" closed="true" strong="G4102">fe</char> <char style="w" closed="true" strong="G5547">en Cristo</char>. 
