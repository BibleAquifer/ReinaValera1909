<verse eid="COL 1:25"/><verse number="26" style="v" sid="COL 1:26"/><char style="add" closed="true">A saber</char>, <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G3466">misterio</char> <char style="w" closed="true" strong="G3588">que</char> <char style="w" closed="true" strong="G0613">había estado oculto</char> <char style="w" closed="true" strong="G0575">desde</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G0165">siglos</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1074">edades</char>, <char style="w" closed="true" strong="G1161">mas</char> <char style="w" closed="true" strong="G3570">ahora</char> <char style="w" closed="true" strong="G5319">ha sido manifestado</char> <char style="w" closed="true" strong="G0846">á sus</char> <char style="w" closed="true" strong="G0040">santos</char>: 
