<verse eid="EZR 10:43"/><verse number="44" style="v" sid="EZR 10:44"/><char style="w" closed="true" strong="H3605">Todos</char> <char style="w" closed="true" strong="H0428">estos</char> <char style="w" closed="true" strong="H5375">habían tomado</char> <char style="w" closed="true" strong="H0802">mujeres</char> <char style="w" closed="true" strong="H5237">extranjeras</char>; <char style="w" closed="true" strong="H3426">y había</char> <char style="w" closed="true" strong="H0802">mujeres</char> <char style="w" closed="true" strong="H1992">de ellos</char> <char style="w" closed="true" strong="H7760">que habían parido</char> <char style="w" closed="true" strong="H1121">hijos</char>.  <verse eid="EZR 10:44"/></para>
