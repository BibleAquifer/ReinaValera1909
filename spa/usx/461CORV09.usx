<verse eid="1CO 4:10"/><verse number="11" style="v" sid="1CO 4:11"/><char style="w" closed="true" strong="G0891">Hasta</char> <char style="w" closed="true" strong="G0737">esta</char> <char style="w" closed="true" strong="G5610">hora</char> <char style="w" closed="true" strong="G3983">hambreamos</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1372">tenemos sed</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1130">estamos desnudos</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2852">somos heridos de golpes</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0790">andamos vagabundos</char>; 
<verse eid="1CO 4:11"/><verse number="12" style="v" sid="1CO 4:12"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G2872">trabajamos</char>, <char style="w" closed="true" strong="G2038">obrando</char> <char style="w" closed="true" strong="G5495">con nuestras manos</char>: <char style="w" closed="true" strong="G3058">nos maldicen</char>, <char style="w" closed="true" strong="G2127">y bendecimos</char>: <char style="w" closed="true" strong="G1377">padecemos persecución</char>, <char style="w" closed="true" strong="G0430">y sufrimos</char>: 
<verse eid="1CO 4:12"/><verse number="13" style="v" sid="1CO 4:13"/><char style="w" closed="true" strong="G0987">Somos blasfemados</char>, <char style="w" closed="true" strong="G3870">y rogamos</char>: <char style="w" closed="true" strong="G1096">hemos venido á ser</char> <char style="w" closed="true" strong="G5613">como</char> <char style="w" closed="true" strong="G4027">la hez</char> <char style="w" closed="true" strong="G3588">del</char> <char style="w" closed="true" strong="G2889">mundo</char>, <char style="w" closed="true" strong="G4067">el desecho</char> <char style="w" closed="true" strong="G3956">de todos</char> <char style="w" closed="true" strong="G2193">hasta</char> <char style="w" closed="true" strong="G0737">ahora</char>. 
<verse eid="1CO 4:13"/><verse number="14" style="v" sid="1CO 4:14"/><char style="w" closed="true" strong="G3756">No</char> <char style="w" closed="true" strong="G1125">escribo</char> <char style="w" closed="true" strong="G5023">esto</char> <char style="w" closed="true" strong="G1788,G5209">para avergonzaros</char>: <char style="w" closed="true" strong="G0235">mas</char> <char style="w" closed="true" strong="G3560">amonéstoos</char> <char style="w" closed="true" strong="G5613">como</char> <char style="w" closed="true" strong="G5043">á mis hijos</char> <char style="w" closed="true" strong="G0027">amados</char>. 
