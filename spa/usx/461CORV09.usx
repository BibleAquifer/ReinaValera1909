<verse eid="1CO 7:15"/><verse number="16" style="v" sid="1CO 7:16"/><char style="w" closed="true" strong="G1063">Porque</char> ¿<char style="w" closed="true" strong="G1492">de dónde sabes</char>, <char style="w" closed="true" strong="G1135">oh mujer</char>, <char style="w" closed="true" strong="G1487">si</char> <char style="w" closed="true" strong="G4982">quizá harás salvo</char> <char style="w" closed="true" strong="G3588">á tu</char> <char style="w" closed="true" strong="G0435">marido</char>? ¿<char style="w" closed="true" strong="G2228">ó</char> <char style="w" closed="true" strong="G1492">de dónde sabes</char>, <char style="w" closed="true" strong="G0435">oh marido</char>, <char style="w" closed="true" strong="G1487">si</char> <char style="w" closed="true" strong="G4982">quizá harás salva</char> <char style="w" closed="true" strong="G3588">á tu</char> <char style="w" closed="true" strong="G1135">mujer</char>? 
