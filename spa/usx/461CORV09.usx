<verse eid="1CO 7:3"/><verse number="4" style="v" sid="1CO 7:4"/><char style="w" closed="true" strong="G3588">La</char> <char style="w" closed="true" strong="G1135">mujer</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G1850">tiene potestad</char> <char style="w" closed="true" strong="G2398">de su propio</char> <char style="w" closed="true" strong="G4983">cuerpo</char>, <char style="w" closed="true" strong="G0235">sino</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0435">marido</char>: <char style="w" closed="true" strong="G1161,G3756">é</char> <char style="w" closed="true" strong="G3668,G2532">igualmente tampoco</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0435">marido</char> <char style="w" closed="true" strong="G1850">tiene potestad</char> <char style="w" closed="true" strong="G2398">de su propio</char> <char style="w" closed="true" strong="G4983">cuerpo</char>, <char style="w" closed="true" strong="G0235">sino</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G1135">mujer</char>. 
