<verse eid="1CO 11:13"/><verse number="14" style="v" sid="1CO 11:14"/><char style="w" closed="true" strong="G3588">La</char> <char style="w" closed="true" strong="G0846">misma</char> <char style="w" closed="true" strong="G5449">naturaleza</char> ¿<char style="w" closed="true" strong="G3761">no</char> <char style="w" closed="true" strong="G5209">os</char> <char style="w" closed="true" strong="G1321">enseña</char> <char style="w" closed="true" strong="G3754">que</char> <char style="w" closed="true" strong="G0435">al hombre</char> <char style="w" closed="true" strong="G0819">sea deshonesto</char> <char style="w" closed="true" strong="G2863">criar cabello</char>? 
<verse eid="1CO 11:14"/><verse number="15" style="v" sid="1CO 11:15"/><char style="w" closed="true" strong="G1161">Por</char> el contrario, <char style="w" closed="true" strong="G1135">á la mujer</char> <char style="w" closed="true" strong="G2863">criar el cabello</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G1391">honroso</char>; <char style="w" closed="true" strong="G3754">porque</char> <char style="w" closed="true" strong="G0473">en lugar</char> <char style="w" closed="true" strong="G4018">de velo</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G1325">dado</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2864">cabello</char>. 
<verse eid="1CO 11:15"/><verse number="16" style="v" sid="1CO 11:16"/><char style="w" closed="true" strong="G1161">Con</char> todo eso, <char style="w" closed="true" strong="G1487">si</char> <char style="w" closed="true" strong="G5100">alguno</char> <char style="w" closed="true" strong="G1511">parece ser</char> <char style="w" closed="true" strong="G5380">contencioso</char>, <char style="w" closed="true" strong="G2249">nosotros</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G2192">tenemos</char> <char style="w" closed="true" strong="G5108">tal</char> <char style="w" closed="true" strong="G4914">costumbre</char>, <char style="w" closed="true" strong="G3761">ni</char> <char style="w" closed="true" strong="G3588">las</char> <char style="w" closed="true" strong="G1577">iglesias</char> <char style="w" closed="true" strong="G2316">de Dios</char>. 
