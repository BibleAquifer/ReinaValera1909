<verse eid="1CO 3:20"/><verse number="21" style="v" sid="1CO 3:21"/><char style="w" closed="true" strong="G5620">Así</char> que, <char style="w" closed="true" strong="G3367">ninguno</char> <char style="w" closed="true" strong="G2744">se gloríe</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G0444">los hombres</char>; <char style="w" closed="true" strong="G1063">porque</char> <char style="w" closed="true" strong="G3956">todo</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G5216">vuestro</char>; 
