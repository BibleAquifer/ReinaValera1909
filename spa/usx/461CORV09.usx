  <para style="p"><verse number="1" style="v" sid="1CO 7:1"/><char style="w" closed="true" strong="G4012">CUANTO</char> <char style="w" closed="true" strong="G3739">á las cosas de que</char> <char style="w" closed="true" strong="G3427">me</char> <char style="w" closed="true" strong="G1125">escribisteis</char>, <char style="w" closed="true" strong="G2570">bien</char> <char style="w" closed="true" strong="G0444">es al hombre</char> <char style="w" closed="true" strong="G3361">no</char> <char style="w" closed="true" strong="G0680">tocar</char> <char style="w" closed="true" strong="G1135">mujer</char>. 
<verse eid="1CO 7:1"/><verse number="2" style="v" sid="1CO 7:2"/><char style="w" closed="true" strong="G1161">Mas</char> <char style="w" closed="true" strong="G1223">á causa</char> <char style="w" closed="true" strong="G3588">de las</char> <char style="w" closed="true" strong="G4202">fornicaciones</char>, <char style="w" closed="true" strong="G1538">cada</char> <char style="w" closed="true" strong="G2192">uno tenga</char> <char style="w" closed="true" strong="G1438">su</char> <char style="w" closed="true" strong="G1135">mujer</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1538">cada</char> <char style="w" closed="true" strong="G2192">una tenga</char> <char style="w" closed="true" strong="G1438">su</char> <char style="w" closed="true" strong="G0435">marido</char>. 
