<verse eid="1CO 11:10"/><verse number="11" style="v" sid="1CO 11:11"/><char style="w" closed="true" strong="G4133">Mas</char> <char style="w" closed="true" strong="G3777">ni</char> <char style="w" closed="true" strong="G0435">el varón</char> <char style="w" closed="true" strong="G5565">sin</char> <char style="w" closed="true" strong="G1135">la mujer</char>, <char style="w" closed="true" strong="G3777">ni</char> <char style="w" closed="true" strong="G1135">la mujer</char> <char style="w" closed="true" strong="G5565">sin</char> <char style="w" closed="true" strong="G0435">el varón</char>, <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G2962">el Señor</char>. 
