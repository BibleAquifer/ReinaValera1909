<verse eid="1CO 7:20"/><verse number="21" style="v" sid="1CO 7:21"/>¿<char style="w" closed="true" strong="G2564">Eres llamado</char> <char style="w" closed="true" strong="G1401">siendo siervo</char>? <char style="w" closed="true" strong="G3361">no</char> <char style="w" closed="true" strong="G4671">se te</char> <char style="w" closed="true" strong="G3199">dé cuidado</char>: <char style="w" closed="true" strong="G0235">mas</char> <char style="w" closed="true" strong="G2532">también</char> <char style="w" closed="true" strong="G1487">si</char> <char style="w" closed="true" strong="G1410">puedes</char> <char style="w" closed="true" strong="G1096">hacerte</char> <char style="w" closed="true" strong="G1658">libre</char>, <char style="w" closed="true" strong="G5530">procúralo</char> <char style="w" closed="true" strong="G3123">más</char>. 
