<verse eid="1CO 9:9"/><verse number="10" style="v" sid="1CO 9:10"/>¿<char style="w" closed="true" strong="G2228">O</char> <char style="w" closed="true" strong="G3004">dícelo</char> <char style="w" closed="true" strong="G3843">enteramente</char> <char style="w" closed="true" strong="G1223">por</char> <char style="w" closed="true" strong="G2248">nosotros</char>? <char style="w" closed="true" strong="G1063">Pues</char> <char style="w" closed="true" strong="G1223">por</char> <char style="w" closed="true" strong="G2248">nosotros</char> <char style="w" closed="true" strong="G1125">está escrito</char>; <char style="w" closed="true" strong="G3754">porque</char> <char style="w" closed="true" strong="G1909">con</char> <char style="w" closed="true" strong="G1680">esperanza</char> <char style="w" closed="true" strong="G0722">ha de arar</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0722">que ara</char>; <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0248">que trilla</char>, <char style="w" closed="true" strong="G1909">con</char> <char style="w" closed="true" strong="G1680">esperanza</char> <char style="w" closed="true" strong="G3348">de recibir</char> <char style="w" closed="true" strong="G1680">el fruto</char>. 
