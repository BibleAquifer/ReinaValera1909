<verse eid="1CO 7:17"/><verse number="18" style="v" sid="1CO 7:18"/>¿<char style="w" closed="true" strong="G2564">Es llamado</char> <char style="w" closed="true" strong="G5100">alguno</char> <char style="w" closed="true" strong="G4059">circuncidado</char>? <char style="w" closed="true" strong="G3361">quédese</char> <char style="w" closed="true" strong="G4059">circunciso</char>. ¿<char style="w" closed="true" strong="G2564">Es llamado</char> <char style="w" closed="true" strong="G5100">alguno</char> <char style="w" closed="true" strong="G1722,G0203">incircuncidado</char>? <char style="w" closed="true" strong="G3361">que no</char> <char style="w" closed="true" strong="G4059">se circuncide</char>. 
