<verse eid="1CO 7:13"/><verse number="14" style="v" sid="1CO 7:14"/><char style="w" closed="true" strong="G1063">Porque</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0435">marido</char> <char style="w" closed="true" strong="G0571">infiel</char> <char style="w" closed="true" strong="G0037">es santificado</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G1135">mujer</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G1135">mujer</char> <char style="w" closed="true" strong="G0571">infiel</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0435">marido</char>: <char style="w" closed="true" strong="G1893">pues</char> <char style="w" closed="true" strong="G0686">de otra manera</char> <char style="w" closed="true" strong="G5216">vuestros</char> <char style="w" closed="true" strong="G5043">hijos</char> <char style="w" closed="true" strong="G2076">serían</char> <char style="w" closed="true" strong="G0169">inmundos</char>; <char style="w" closed="true" strong="G1161">empero</char> <char style="w" closed="true" strong="G3568">ahora</char> <char style="w" closed="true" strong="G2076">son</char> <char style="w" closed="true" strong="G0040">santos</char>. 
