  <para style="p"><verse number="1" style="v" sid="MAT 26:1"/><char style="w" closed="true" strong="G2532">Y</char> ACONTECIÓ que, <char style="w" closed="true" strong="G3753">como</char> <char style="w" closed="true" strong="G1096">hubo</char> <char style="w" closed="true" strong="G5055">acabado</char> <char style="w" closed="true" strong="G2424">Jesús</char> <char style="w" closed="true" strong="G3956">todas</char> <char style="w" closed="true" strong="G5128">estas</char> <char style="w" closed="true" strong="G3056">palabras</char>, <char style="w" closed="true" strong="G2036">dijo</char> <char style="w" closed="true" strong="G0846">á sus</char> <char style="w" closed="true" strong="G3101">discípulos</char>: 
