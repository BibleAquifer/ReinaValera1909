<verse eid="LEV 13:38"/><verse number="39" style="v" sid="LEV 13:39"/><char style="w" closed="true" strong="H3548">El sacerdote</char> <char style="w" closed="true" strong="H7200">mirará</char>: <char style="w" closed="true" strong="H5785">y si en la piel</char> <char style="w" closed="true" strong="H1320">de su carne</char> <char style="w" closed="true" strong="H0934">parecieren manchas</char> <char style="w" closed="true" strong="H3836">blancas</char> algo oscurecidas, <char style="w" closed="true" strong="H0933">es empeine</char> <char style="w" closed="true" strong="H6524">que brotó</char> <char style="w" closed="true" strong="H5785">en la piel</char>, <char style="w" closed="true" strong="H2889">está limpia</char> la persona. 
