<verse eid="GEN 5:28"/><verse number="29" style="v" sid="GEN 5:29"/><char style="w" closed="true" strong="H7121">Y llamó</char> <char style="w" closed="true" strong="H8034">su nombre</char> <char style="w" closed="true" strong="H5146">Noé</char>, <char style="w" closed="true" strong="H0559">diciendo</char>: <char style="w" closed="true" strong="H2088">Este</char> <char style="w" closed="true" strong="H0587">nos</char> <char style="w" closed="true" strong="H5162">aliviará</char> <char style="w" closed="true" strong="H4480">de</char> <char style="w" closed="true" strong="H0587">nuestras</char> <char style="w" closed="true" strong="H4639">obras</char>, <char style="w" closed="true" strong="H4480">y del</char> <char style="w" closed="true" strong="H6093">trabajo</char> <char style="w" closed="true" strong="H4480">de</char> <char style="w" closed="true" strong="H0587">nuestras</char> <char style="w" closed="true" strong="H3027">manos</char>, <char style="w" closed="true" strong="H4480">á causa</char> <char style="w" closed="true" strong="H4480">de</char> <char style="w" closed="true" strong="H0127">la tierra</char> <char style="w" closed="true" strong="H0834">que</char> <char style="w" closed="true" strong="H3068">Jehová</char> <char style="w" closed="true" strong="H0779">maldijo</char>. 
<verse eid="GEN 5:29"/><verse number="30" style="v" sid="GEN 5:30"/><char style="w" closed="true" strong="H2421">Y vivió</char> <char style="w" closed="true" strong="H3929">Lamech</char>, <char style="w" closed="true" strong="H0310">después</char> <char style="w" closed="true" strong="H3205">que engendró</char> <char style="w" closed="true" strong="H5146">á Noé</char>, <char style="w" closed="true" strong="H2568,H3967">quinientos</char> <char style="w" closed="true" strong="H8673">noventa</char> <char style="w" closed="true" strong="H2568">y cinco</char> <char style="w" closed="true" strong="H8141">años</char>: <char style="w" closed="true" strong="H3205">y engendró</char> <char style="w" closed="true" strong="H1121">hijos</char> <char style="w" closed="true" strong="H1323">é hijas</char>. 
