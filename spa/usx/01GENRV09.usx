<verse eid="GEN 5:11"/><verse number="12" style="v" sid="GEN 5:12"/><char style="w" closed="true" strong="H2421">Y vivió</char> <char style="w" closed="true" strong="H7018">Cainán</char> <char style="w" closed="true" strong="H7657">setenta</char> <char style="w" closed="true" strong="H8141">años</char>, <char style="w" closed="true" strong="H3205">y engendró</char> <char style="w" closed="true" strong="H4111">á Mahalaleel</char>. 
