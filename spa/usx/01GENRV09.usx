<verse eid="GEN 5:8"/><verse number="9" style="v" sid="GEN 5:9"/><char style="w" closed="true" strong="H2421">Y vivió</char> <char style="w" closed="true" strong="H0583">Enós</char> <char style="w" closed="true" strong="H8673">noventa</char> <char style="w" closed="true" strong="H8141">años</char>, <char style="w" closed="true" strong="H3205">y engendró</char> <char style="w" closed="true" strong="H7018">á Cainán</char>. 
<verse eid="GEN 5:9"/><verse number="10" style="v" sid="GEN 5:10"/><char style="w" closed="true" strong="H2421">Y vivió</char> <char style="w" closed="true" strong="H0583">Enós</char> <char style="w" closed="true" strong="H0310">después</char> <char style="w" closed="true" strong="H3205">que engendró</char> <char style="w" closed="true" strong="H7018">á Cainán</char>, <char style="w" closed="true" strong="H8083,H3967">ochocientos</char> <char style="w" closed="true" strong="H2568">y quince</char> <char style="w" closed="true" strong="H8141">años</char>: <char style="w" closed="true" strong="H3205">y engendró</char> <char style="w" closed="true" strong="H1121">hijos</char> <char style="w" closed="true" strong="H1323">é hijas</char>. 
