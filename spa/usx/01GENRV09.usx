<verse eid="GEN 5:13"/><verse number="14" style="v" sid="GEN 5:14"/><char style="w" closed="true" strong="H1961">Y fueron</char> <char style="w" closed="true" strong="H3605">todos</char> <char style="w" closed="true" strong="H3117">los días</char> <char style="w" closed="true" strong="H7018">de Cainán</char> <char style="w" closed="true" strong="H8672,H3967">novecientos</char> <char style="w" closed="true" strong="H6235">y diez</char> <char style="w" closed="true" strong="H8141">años</char>; <char style="w" closed="true" strong="H4191">y murió</char>. 
