<verse eid="GEN 5:31"/><verse number="32" style="v" sid="GEN 5:32"/><char style="w" closed="true" strong="H1961">Y siendo</char> <char style="w" closed="true" strong="H5146">Noé</char> <char style="w" closed="true" strong="H2568,H3967">de quinientos</char> <char style="w" closed="true" strong="H8141">años</char>, <char style="w" closed="true" strong="H3205">engendró</char> <char style="w" closed="true" strong="H8035">á Sem</char>, <char style="w" closed="true" strong="H2526">Châm</char>, <char style="w" closed="true" strong="H3315">y á Japhet</char>.  
