<verse eid="JAS 4:14"/><verse number="15" style="v" sid="JAS 4:15"/><char style="w" closed="true" strong="G0473">En lugar</char> <char style="w" closed="true" strong="G3588">de lo</char> <char style="w" closed="true" strong="G5209">cual deberíais</char> <char style="w" closed="true" strong="G3004">decir</char>: <char style="w" closed="true" strong="G1437">Si</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2962">Señor</char> <char style="w" closed="true" strong="G2309">quisiere</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1437">si</char> <char style="w" closed="true" strong="G2198">viviéremos</char>, <char style="w" closed="true" strong="G4160">haremos</char> <char style="w" closed="true" strong="G5124">esto</char> <char style="w" closed="true" strong="G2228">ó</char> <char style="w" closed="true" strong="G1565">aquello</char>. 
<verse eid="JAS 4:15"/><verse number="16" style="v" sid="JAS 4:16"/><char style="w" closed="true" strong="G1161">Mas</char> <char style="w" closed="true" strong="G3568">ahora</char> <char style="w" closed="true" strong="G2744">os jactáis</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G5216">vuestras</char> <char style="w" closed="true" strong="G0212">soberbias</char>. <char style="w" closed="true" strong="G3956">Toda</char> <char style="w" closed="true" strong="G2746">jactancia</char> <char style="w" closed="true" strong="G5108">semejante</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G4190">mala</char>. 
<verse eid="JAS 4:16"/><verse number="17" style="v" sid="JAS 4:17"/><char style="w" closed="true" strong="G0266">El pecado</char>, pues, <char style="w" closed="true" strong="G2076">está</char> <char style="w" closed="true" strong="G0846">en aquel</char> <char style="w" closed="true" strong="G1492">que sabe</char> <char style="w" closed="true" strong="G4160">hacer</char> <char style="w" closed="true" strong="G2570">lo bueno</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3361">no</char> <char style="w" closed="true" strong="G4160">lo hace</char>.  
