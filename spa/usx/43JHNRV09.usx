<verse eid="JHN 18:3"/><verse number="4" style="v" sid="JHN 18:4"/><char style="w" closed="true" strong="G3767">Empero</char> <char style="w" closed="true" strong="G2424">Jesús</char>, <char style="w" closed="true" strong="G1492">sabiendo</char> <char style="w" closed="true" strong="G3956">todas</char> <char style="w" closed="true" strong="G3588">las cosas que</char> <char style="w" closed="true" strong="G2064">habían de venir</char> <char style="w" closed="true" strong="G1909">sobre</char> <char style="w" closed="true" strong="G0846">él</char>, <char style="w" closed="true" strong="G1831">salió delante</char>, <char style="w" closed="true" strong="G2036,G0846">y díjoles</char>: ¿<char style="w" closed="true" strong="G5101">A quién</char> <char style="w" closed="true" strong="G2212">buscáis</char>? 
<verse eid="JHN 18:4"/><verse number="5" style="v" sid="JHN 18:5"/><char style="w" closed="true" strong="G0611,G0846">Respondiéronle</char>: <char style="w" closed="true" strong="G2424">A Jesús</char> <char style="w" closed="true" strong="G3480">Nazareno</char>. <char style="w" closed="true" strong="G3004,G0846">Díceles</char> <char style="w" closed="true" strong="G2424">Jesús</char>: <char style="w" closed="true" strong="G1473">Yo</char> <char style="w" closed="true" strong="G1510">soy</char>. (<char style="w" closed="true" strong="G1161">Y</char> <char style="w" closed="true" strong="G2476">estaba</char> <char style="w" closed="true" strong="G2532">también</char> <char style="w" closed="true" strong="G3326">con</char> <char style="w" closed="true" strong="G0846">ellos</char> <char style="w" closed="true" strong="G2455">Judas</char>, <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G0846">que le</char> <char style="w" closed="true" strong="G3860">entregaba</char>.) 
<verse eid="JHN 18:5"/><verse number="6" style="v" sid="JHN 18:6"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G0846">como les</char> <char style="w" closed="true" strong="G2036">dijo</char>, <char style="w" closed="true" strong="G1473">Yo</char> <char style="w" closed="true" strong="G1510">soy</char>, <char style="w" closed="true" strong="G0565">volvieron</char> <char style="w" closed="true" strong="G1519,G3694">atrás</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G4098">cayeron</char> <char style="w" closed="true" strong="G5476">en tierra</char>. 
<verse eid="JHN 18:6"/><verse number="7" style="v" sid="JHN 18:7"/><char style="w" closed="true" strong="G3825,G0846">Volvióles</char>, <char style="w" closed="true" strong="G3767">pues</char>, <char style="w" closed="true" strong="G1905">á preguntar</char>: ¿<char style="w" closed="true" strong="G5101">A quién</char> <char style="w" closed="true" strong="G2212">buscáis</char>? <char style="w" closed="true" strong="G1161">Y</char> <char style="w" closed="true" strong="G3588">ellos</char> <char style="w" closed="true" strong="G2036">dijeron</char>: <char style="w" closed="true" strong="G2424">A Jesús</char> <char style="w" closed="true" strong="G3480">Nazareno</char>. 
