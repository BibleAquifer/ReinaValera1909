<verse eid="JHN 12:4"/><verse number="5" style="v" sid="JHN 12:5"/>¿<char style="w" closed="true" strong="G1302">Por qué</char> <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G4097">se ha vendido</char> <char style="w" closed="true" strong="G5124">este</char> <char style="w" closed="true" strong="G3464">ungüento</char> <char style="w" closed="true" strong="G5145">por trescientos</char> <char style="w" closed="true" strong="G1220">dineros</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1325">se dió</char> <char style="w" closed="true" strong="G4434">á los pobres</char>? 
<verse eid="JHN 12:5"/><verse number="6" style="v" sid="JHN 12:6"/><char style="w" closed="true" strong="G1161">Mas</char> <char style="w" closed="true" strong="G2036">dijo</char> <char style="w" closed="true" strong="G5124">esto</char>, <char style="w" closed="true" strong="G3756">no</char> <char style="w" closed="true" strong="G3754">por</char> <char style="w" closed="true" strong="G3199">el cuidado</char> <char style="w" closed="true" strong="G0846">que él</char> <char style="w" closed="true" strong="G4012">tenía de</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G4434">pobres</char>; <char style="w" closed="true" strong="G0235">sino</char> <char style="w" closed="true" strong="G3754">porque</char> <char style="w" closed="true" strong="G2258">era</char> <char style="w" closed="true" strong="G2812">ladrón</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G2192">tenía</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G1101">bolsa</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0941">traía</char> <char style="w" closed="true" strong="G3588">lo</char> <char style="w" closed="true" strong="G0906">que se echaba</char> en ella. 
