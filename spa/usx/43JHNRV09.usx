<verse eid="JHN 18:8"/><verse number="9" style="v" sid="JHN 18:9"/><char style="w" closed="true" strong="G2443">Para que</char> <char style="w" closed="true" strong="G4137">se cumpliese</char> <char style="w" closed="true" strong="G3056">la palabra</char> <char style="w" closed="true" strong="G3739">que</char> <char style="w" closed="true" strong="G2036">había dicho</char>: <char style="w" closed="true" strong="G3739">De los que</char> <char style="w" closed="true" strong="G3427">me</char> <char style="w" closed="true" strong="G1325">diste</char>, <char style="w" closed="true" strong="G3762">ninguno</char> <char style="w" closed="true" strong="G1537">de</char> <char style="w" closed="true" strong="G0846">ellos</char> <char style="w" closed="true" strong="G0622">perdí</char>. 
