<verse eid="JHN 12:9"/><verse number="10" style="v" sid="JHN 12:10"/><char style="w" closed="true" strong="G1011">Consultaron</char> <char style="w" closed="true" strong="G3588">asimismo los</char> <char style="w" closed="true" strong="G0749">príncipes de los sacerdotes</char>, <char style="w" closed="true" strong="G2443,G0615">de matar</char> <char style="w" closed="true" strong="G2532">también</char> <char style="w" closed="true" strong="G2976">á Lázaro</char>; 
