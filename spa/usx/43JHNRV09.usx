<verse eid="JHN 5:8"/><verse number="9" style="v" sid="JHN 5:9"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G2112">luego</char> <char style="w" closed="true" strong="G3588">aquel</char> <char style="w" closed="true" strong="G0444">hombre</char> <char style="w" closed="true" strong="G1096">fué</char> <char style="w" closed="true" strong="G5199">sano</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0142">tomó</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G2895">lecho</char>, <char style="w" closed="true" strong="G2532">é</char> <char style="w" closed="true" strong="G4043">íbase</char>. <char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G2258">era</char> <char style="w" closed="true" strong="G4521">sábado</char> <char style="w" closed="true" strong="G1722,G1565">aquel</char> <char style="w" closed="true" strong="G2250">día</char>. 
