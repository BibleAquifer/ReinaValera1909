  <para style="p"><verse number="1" style="v" sid="JHN 18:1"/><char style="w" closed="true" strong="G2424">COMO Jesús</char> <char style="w" closed="true" strong="G2036">hubo dicho</char> <char style="w" closed="true" strong="G5023">estas</char> cosas, <char style="w" closed="true" strong="G1831">salióse</char> <char style="w" closed="true" strong="G4862">con</char> <char style="w" closed="true" strong="G0846">sus</char> <char style="w" closed="true" strong="G3101">discípulos</char> <char style="w" closed="true" strong="G4008">tras</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G5493">arroyo</char> <char style="w" closed="true" strong="G2748">de Cedrón</char>, <char style="w" closed="true" strong="G3699">donde</char> <char style="w" closed="true" strong="G2258">estaba</char> <char style="w" closed="true" strong="G2779">un huerto</char>, <char style="w" closed="true" strong="G1519">en</char> <char style="w" closed="true" strong="G3739">el cual</char> <char style="w" closed="true" strong="G1525">entró</char> <char style="w" closed="true" strong="G2424">Jesús</char> <char style="w" closed="true" strong="G0846">y sus</char> <char style="w" closed="true" strong="G3101">discípulos</char>. 
