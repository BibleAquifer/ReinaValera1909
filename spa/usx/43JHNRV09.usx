<verse eid="JHN 18:11"/><verse number="12" style="v" sid="JHN 18:12"/><char style="w" closed="true" strong="G3767">Entonces</char> <char style="w" closed="true" strong="G3588">la</char> <char style="w" closed="true" strong="G4686">compañía</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G5506">tribuno</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G5257">ministros</char> <char style="w" closed="true" strong="G3588">de los</char> <char style="w" closed="true" strong="G2453">Judíos</char>, <char style="w" closed="true" strong="G4815">prendieron</char> <char style="w" closed="true" strong="G2424">á Jesús</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G0846">le</char> <char style="w" closed="true" strong="G1210">ataron</char>, 
