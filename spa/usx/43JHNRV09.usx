<verse eid="JHN 21:23"/><verse number="24" style="v" sid="JHN 21:24"/><char style="w" closed="true" strong="G3778">Este</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G3101">aquel discípulo</char> <char style="w" closed="true" strong="G3588">que</char> <char style="w" closed="true" strong="G3140">da testimonio</char> <char style="w" closed="true" strong="G4012">de</char> <char style="w" closed="true" strong="G5130">estas</char> cosas, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1125">escribió</char> <char style="w" closed="true" strong="G5023">estas</char> cosas: <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1492">sabemos</char> <char style="w" closed="true" strong="G3754">que</char> <char style="w" closed="true" strong="G0846">su</char> <char style="w" closed="true" strong="G3141">testimonio</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G0227">verdadero</char>. 
<verse eid="JHN 21:24"/><verse number="25" style="v" sid="JHN 21:25"/><char style="w" closed="true" strong="G1161">Y</char> <char style="w" closed="true" strong="G2076">hay</char> <char style="w" closed="true" strong="G2532">también</char> <char style="w" closed="true" strong="G0243">otras</char> <char style="w" closed="true" strong="G4183,G3745">muchas</char> <char style="w" closed="true" strong="G4160">cosas que hizo</char> <char style="w" closed="true" strong="G2424">Jesús</char>, <char style="w" closed="true" strong="G1437">que si</char> <char style="w" closed="true" strong="G1125">se escribiesen</char> <char style="w" closed="true" strong="G1520">cada una</char> <char style="w" closed="true" strong="G2596">por</char> sí, <char style="w" closed="true" strong="G3761">ni</char> <char style="w" closed="true" strong="G3588">aun en el</char> <char style="w" closed="true" strong="G2889">mundo</char> <char style="w" closed="true" strong="G3633">pienso</char> <char style="w" closed="true" strong="G5562">que cabrían</char> <char style="w" closed="true" strong="G3588">los</char> <char style="w" closed="true" strong="G0975">libros</char> <char style="w" closed="true" strong="G1125">que se habrían de escribir</char>. <char style="w" closed="true" strong="G0281">Amén</char>.  <verse eid="JHN 21:25"/></para>
