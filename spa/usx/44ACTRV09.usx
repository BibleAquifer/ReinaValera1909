<verse eid="ACT 25:24"/><verse number="25" style="v" sid="ACT 25:25"/><char style="w" closed="true" strong="G1161">Mas</char> <char style="w" closed="true" strong="G1473">yo</char>, <char style="w" closed="true" strong="G2638">hallando</char> <char style="w" closed="true" strong="G3367">que ninguna</char> <char style="w" closed="true" strong="G0514">cosa digna</char> <char style="w" closed="true" strong="G2288">de muerte</char> <char style="w" closed="true" strong="G4238">ha hecho</char>, <char style="w" closed="true" strong="G1161">y</char> <char style="w" closed="true" strong="G5127">él</char> <char style="w" closed="true" strong="G0846">mismo</char> <char style="w" closed="true" strong="G1941">apelando</char> <char style="w" closed="true" strong="G0828">á Augusto</char>, <char style="w" closed="true" strong="G2919">he determinado</char> <char style="w" closed="true" strong="G3992">enviarle</char>: 
<verse eid="ACT 25:25"/><verse number="26" style="v" sid="ACT 25:26"/><char style="w" closed="true" strong="G3756">Del cual no</char> <char style="w" closed="true" strong="G2192">tengo</char> <char style="w" closed="true" strong="G5100">cosa</char> <char style="w" closed="true" strong="G0804">cierta</char> <char style="w" closed="true" strong="G1125">que escriba</char> <char style="w" closed="true" strong="G2962">al señor</char>; <char style="w" closed="true" strong="G0846">por lo que le</char> <char style="w" closed="true" strong="G4254">he sacado</char> <char style="w" closed="true" strong="G1909">á</char> <char style="w" closed="true" strong="G5216">vosotros</char>, <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G3122">mayormente</char> <char style="w" closed="true" strong="G1909">á</char> <char style="w" closed="true" strong="G4675">tí</char>, <char style="w" closed="true" strong="G0935">oh rey</char> <char style="w" closed="true" strong="G0067">Agripa</char>, <char style="w" closed="true" strong="G3704">para que</char> <char style="w" closed="true" strong="G0351">hecha información</char>, <char style="w" closed="true" strong="G2192">tenga</char> <char style="w" closed="true" strong="G5100">yo qué</char> <char style="w" closed="true" strong="G1125">escribir</char>. 
