<verse eid="1TI 3:14"/><verse number="15" style="v" sid="1TI 3:15"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G1437">si</char> <char style="w" closed="true" strong="G1019">no fuere tan presto</char>, <char style="w" closed="true" strong="G2443">para que</char> <char style="w" closed="true" strong="G1492">sepas</char> <char style="w" closed="true" strong="G4459">cómo</char> <char style="w" closed="true" strong="G1163">te conviene</char> <char style="w" closed="true" strong="G0390">conversar</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3624">la casa</char> <char style="w" closed="true" strong="G2316">de Dios</char>, <char style="w" closed="true" strong="G3748">que</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G1577">la iglesia</char> <char style="w" closed="true" strong="G2316">del Dios</char> <char style="w" closed="true" strong="G2198">vivo</char>, <char style="w" closed="true" strong="G4769">columna</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G1477">apoyo</char> <char style="w" closed="true" strong="G3588">de la</char> <char style="w" closed="true" strong="G0225">verdad</char>. 
<verse eid="1TI 3:15"/><verse number="16" style="v" sid="1TI 3:16"/><char style="w" closed="true" strong="G2532">Y</char> <char style="w" closed="true" strong="G3672">sin contradicción</char>, <char style="w" closed="true" strong="G3173">grande</char> <char style="w" closed="true" strong="G2076">es</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G3466">misterio</char> <char style="w" closed="true" strong="G3588">de la</char> <char style="w" closed="true" strong="G2150">piedad</char>: <char style="w" closed="true" strong="G2316">Dios</char> <char style="w" closed="true" strong="G5319">ha sido manifestado</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G4561">carne</char>; <char style="w" closed="true" strong="G1344">ha sido justificado</char> <char style="w" closed="true" strong="G3588">con el</char> <char style="w" closed="true" strong="G4151">Espíritu</char>; <char style="w" closed="true" strong="G3700">ha sido visto</char> <char style="w" closed="true" strong="G0032">de los ángeles</char>; <char style="w" closed="true" strong="G2784">ha sido predicado</char> <char style="w" closed="true" strong="G1722">á</char> <char style="w" closed="true" strong="G1483">los Gentiles</char>; <char style="w" closed="true" strong="G4100">ha sido creído</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G3588">el</char> <char style="w" closed="true" strong="G2889">mundo</char>; <char style="w" closed="true" strong="G0353">ha sido recibido</char> <char style="w" closed="true" strong="G1722">en</char> <char style="w" closed="true" strong="G1391">gloria</char>.  
<verse eid="1TI 3:16"/><verse eid="1TI 3:16"/></para>
