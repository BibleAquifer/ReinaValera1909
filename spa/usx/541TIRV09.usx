<verse eid="1TI 6:7"/><verse number="8" style="v" sid="1TI 6:8"/><char style="w" closed="true" strong="G1161">Así</char> que, <char style="w" closed="true" strong="G2192">teniendo</char> <char style="w" closed="true" strong="G1305">sustento</char> <char style="w" closed="true" strong="G2532">y</char> <char style="w" closed="true" strong="G4629">con qué cubrirnos</char>, <char style="w" closed="true" strong="G0714">seamos contentos</char> <char style="w" closed="true" strong="G5125">con esto</char>. 
